# AWS Configuration (for DynamoDB)
APP_AWS_REGION=ap-south-1
APP_AWS_ACCESS_KEY_ID=your_aws_access_key
APP_AWS_SECRET_ACCESS_KEY=your_aws_secret_key

# Cognito Configuration (may be in different region)
COGNITO_REGION=ap-southeast-1
NEXT_PUBLIC_COGNITO_USER_POOL_ID=ap-southeast-1_XXXXXXXXX
NEXT_PUBLIC_COGNITO_CLIENT_ID=your_cognito_client_id
COGNITO_CLIENT_SECRET=your_cognito_client_secret

# DynamoDB Tables
DYNAMODB_USERS_TABLE=ai-d-mart-users
DYNAMODB_DATA_TABLE=ai-d-mart-data

# Resend Email Service
RESEND_API_KEY=re_XXXXXXXXX
RESEND_FROM_EMAIL=onboarding@resend.dev

# App
NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app
